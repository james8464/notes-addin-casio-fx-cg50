#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="${TMPDIR:-/tmp}/khicas_host_runner_cascas"
SRC="${TMPDIR:-/tmp}/khicas_host_runner_cascas.cpp"
LOCK="${BIN}.lock"
WORKING="${ROOT}/khicas/upstream/giac90_1addin/cascas_working.cc"
HEADER="${ROOT}/khicas/upstream/giac90_1addin/cascas_working.h"

if [ ! -x "${BIN}" ] || [ "${WORKING}" -nt "${BIN}" ] || [ "${HEADER}" -nt "${BIN}" ]; then
  while ! mkdir "${LOCK}" 2>/dev/null; do sleep 0.05; done
  trap 'rmdir "${LOCK}" 2>/dev/null || true' EXIT
fi

if [ ! -x "${BIN}" ] || [ "${WORKING}" -nt "${BIN}" ] || [ "${HEADER}" -nt "${BIN}" ]; then
  cat > "${SRC}" <<'CPP'
#include <iostream>
#include <string>
#include "cascas_working.h"

static bool starts(const std::string &s,const char *p){
  return s.rfind(p,0)==0;
}

int main(int argc,char **argv){
  std::string mode="--alg", input;
  for (int i=1;i<argc;++i){
    std::string a=argv[i];
    if (starts(a,"--"))
      mode=a;
    else {
      if (!input.empty()) input += " ";
      input += a;
    }
  }
  if (input.empty())
    return 0;
  std::string routed=input;
  if (mode=="--derive" && !starts(input,"diff(") && !starts(input,"derive("))
    routed="diff("+input+")";
  if (mode=="--int" && !starts(input,"integrate(") && !starts(input,"int(") && !starts(input,"defint("))
    routed="integrate("+input+")";
  cascas::working_string out;
  if (cascas::eval_with_working(routed.c_str(),out)){
    std::cout << out << "\n";
    return 0;
  }
  std::cout << "General A-level route:\n";
  std::cout << "Input: " << input << "\n";
  std::cout << "Use exact KhiCAS simplification, then write each algebraic or calculus step clearly.\n";
  std::cout << "Answer: run the expression in KhiCAS if no dedicated working route is available.\n";
  return 0;
}
CPP
  g++ -std=c++11 -DCASCAS_HOST_STD_STRING -iquote "${ROOT}/khicas/upstream/giac90_1addin" "${SRC}" "${WORKING}" -o "${BIN}"
fi
rmdir "${LOCK}" 2>/dev/null || true
trap - EXIT

exec "${BIN}" "$@"
