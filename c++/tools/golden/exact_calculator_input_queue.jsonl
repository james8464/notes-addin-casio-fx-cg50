{"id":"madas_iygb_c2_x_q2_exact_inputs","source_pdf":"MadAsMaths papers/c2_x.pdf","question":"q2","part":"all","verdict":"testable","review_basis":"manual page-image review: c2_x questions page 2, marks page 1, solutions page 1","inputs":[{"module":"algebra","input":"solve([1/2*r^2*theta=15,2*r+r*theta=23],[r,theta])","mark_scheme_working":["area gives 1/2*r^2*theta=15, so r^2*theta=30","perimeter gives 2r+rtheta=23, so rtheta=23-2r","substitution gives 1/2*r(23-2r)=15","2r^2-23r+30=0","r=3/2 gives theta=40/3>2pi, so reject; r=10 gives theta=0.3"],"expected_output_markers":["2*r^2 - 23*r + 30 = 0","r = 3/2 => theta = 40/3 rejected, theta > 2*pi","(r,theta) = [(10,3/10)]"]}],"expected_final":["r=10","theta=0.3"]}
