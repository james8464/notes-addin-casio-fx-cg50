{"id":"madas_iygb_c2_v_q6_exact_inputs","source_pdf":"MadAsMaths papers/c2_v.pdf","question":"q6","part":"all","verdict":"partial","review_basis":"manual page-image review: c2_v questions page 4, marks page 3, solutions page 4","inputs":[{"module":"algebra","input":"solve(10=12+3*sin(pi*t/6),t)","mark_scheme_working":["10=12+3sin(pi*t/6)","sin(pi*t/6)=-2/3","pi*t/6=-0.7297+2pi*n or 3.8713+2pi*n","after noon gives t=19.394 and t=22.606","times are about 19:24 and 22:36"],"expected_output_markers":["u = -2/3","t = 7.39367716319 + n*12 or 10.6063228368 + n*12"]}],"expected_final":["19:24 and 22:36"],"unsupported_reason":"choosing after-noon branches and clock notation is manual"}
{"id":"madas_iygb_c2_v_q7_exact_inputs","source_pdf":"MadAsMaths papers/c2_v.pdf","question":"q7","part":"a-d","verdict":"partial","review_basis":"manual page-image review: c2_v questions page 5, marks page 3, solutions pages 4-5","inputs":[{"module":"algebra","input":"solve(y-16/3=4/3*(x-4),y)","mark_scheme_working":["circle rewrites to x^2+(y-25/3)^2=25, so C=(0,25/3), r=5","gradient AC=(25/3-16/3)/(0-4)=-3/4","tangent gradient is 4/3","line through A is y-16/3=(4/3)(x-4), so y=4x/3 and it passes through O"],"expected_output_markers":["y = 4/3*(x - 4) + 16/3"]},{"module":"algebra","input":"method=numeric,100/3-1/2*25*1.8546","mark_scheme_working":["angle BCA is about 1.8546 radians","kite area is 100/3","sector area is 1/2*5^2*1.8546","shaded area is about 10.15"],"expected_output_markers":["10.1508333333"]}],"expected_final":["C=(0,25/3), r=5","line l1 passes through origin","angle about 1.8546","shaded area about 10.15"],"unsupported_reason":"circle rewrite, cosine-rule angle proof and rounding remain manual/contextual"}
{"id":"madas_iygb_c2_v_q8_exact_inputs","source_pdf":"MadAsMaths papers/c2_v.pdf","question":"q8","part":"a-e","verdict":"partial","review_basis":"manual page-image review: c2_v questions page 6, marks page 4, solutions page 6","inputs":[{"module":"derive","input":"1/2*x^2+16*sqrt(2)/x","mark_scheme_working":["A=1/2*x^2+16sqrt(2)/x","dA/dx=x-16sqrt(2)/x^2","set derivative equal to zero"],"expected_output_markers":["dy/dx = x - 16*sqrt(2)*x^-2"]},{"module":"algebra","input":"solve(x-16*sqrt(2)/x^2=0,x)","mark_scheme_working":["x-16sqrt(2)/x^2=0","x^3=16sqrt(2)","x=2sqrt(2)"],"expected_output_markers":["x^3 = 16*sqrt(2)","x = [2*sqrt(2)]"]},{"module":"derive","input":"x-16*sqrt(2)*x^-2","mark_scheme_working":["second derivative is 1+32sqrt(2)x^-3","substitute x=2sqrt(2)","second derivative is positive, so the stationary point is a minimum"],"expected_output_markers":["dy/dx = 32*sqrt(2)*x^-3 + 1"]},{"module":"algebra","input":"1/2*(2*sqrt(2))^2+16*sqrt(2)/(2*sqrt(2))","mark_scheme_working":["minimum area is A at x=2sqrt(2)","A=1/2(2sqrt(2))^2+16sqrt(2)/(2sqrt(2))","A=12"],"expected_output_markers":["= 12"]},{"module":"algebra","input":"sqrt(2)/2*2*sqrt(2)","mark_scheme_working":["EF=(sqrt(2)/2)x","at x=2sqrt(2), EF=2","also y=16/x^2=2, so ED=EB"],"expected_output_markers":["= 2"]}],"expected_final":["x=2sqrt(2)","minimum area=12","ED=EB"],"unsupported_reason":"surface-area formula derivation and prism geometry wording are manual"}
{"id":"madas_iygb_c2_w_q1_exact_inputs","source_pdf":"MadAsMaths papers/c2_w.pdf","question":"q1","part":"all","verdict":"partial","review_basis":"manual page-image review: c2_w questions page 2, marks page 1, solutions page 1","inputs":[{"module":"algebra","input":"method=numeric,18/25*sqrt(3)+12*pi/5","mark_scheme_working":["angle BOC=pi-5pi/6=pi/6","OC=2.4cos(pi/6)=6sqrt(3)/5 and BC=2.4sin(pi/6)=6/5","area triangle OBC=1/2*(6sqrt(3)/5)*(6/5)=18sqrt(3)/25","area sector AOB=1/2*2.4^2*(5pi/6)=12pi/5","total area=18sqrt(3)/25+12pi/5=8.79 to 2 dp"],"expected_output_markers":["18/25*sqrt(3) + 12*pi/5","8.78689895007"]}],"expected_final":["area=8.79"],"unsupported_reason":"diagram angle/triangle setup is manual"}
{"id":"madas_iygb_c2_w_q2_exact_inputs","source_pdf":"MadAsMaths papers/c2_w.pdf","question":"q2","part":"all","verdict":"testable","review_basis":"manual page-image review: c2_w questions page 2, marks page 1, solutions page 1","inputs":[{"module":"derive","input":"(x^2+4)/(4*x)","mark_scheme_working":["y=(x^2+4)/(4x)=x/4+x^-1","dy/dx=1/4-x^-2","increasing when dy/dx>0"],"expected_output_markers":["dy/dx = - x^-2 + 1/4"]},{"module":"algebra","input":"solve(1/4-1/x^2>0,x)","mark_scheme_working":["1/4-1/x^2>0","x^2>4","critical values are -2 and 2","x<-2 or x>2"],"expected_output_markers":["N = 0: x = -2, 2","x < -2 or x > 2"]}],"expected_final":["x<-2 or x>2"]}
