{"id":"madas_iygb_c2_w_q5_exact_inputs","source_pdf":"MadAsMaths papers/c2_w.pdf","question":"q5","part":"a-c","verdict":"testable","review_basis":"manual page-image review: c2_w questions page 3, marks page 3, solutions page 3","inputs":[{"module":"algebra","input":"3^3-2*3^2-3-6","mark_scheme_working":["f(3)=3^3-2(3^2)-3-6","f(3)=27-18-3-6=0","therefore x-3 is a factor"],"expected_output_markers":["0"]},{"module":"algebra","input":"factor(x^3-2*x^2-x-6)","mark_scheme_working":["write f(x)=(x-3)(x^2+Ax+B)","compare coefficients or divide by x-3","f(x)=(x-3)(x^2+x+2)"],"expected_output_markers":["(x - 3)*(x^2 + x + 2)"]},{"module":"derive","input":"3*x^4-8*x^3-6*x^2-72*x+240","mark_scheme_working":["dy/dx=12x^3-24x^2-12x-72","dy/dx=12(x^3-2x^2-x-6)","dy/dx=12(x-3)(x^2+x+2)"],"expected_output_markers":["dy/dx = 12*x^3 - 24*x^2 - 12*x - 72"]},{"module":"algebra","input":"solve(12*x^3-24*x^2-12*x-72=0,x)","mark_scheme_working":["12x^3-24x^2-12x-72=0","(x-3)(12x^2+12x+24)=0","quadratic discriminant is negative, so the only real stationary value is x=3"],"expected_output_markers":["(x - 3)*(12*x^2 + 12*x + 24) = 0","D = -1008 < 0 => No real roots","x = [3]"]},{"module":"algebra","input":"3*3^4-8*3^3-6*3^2-72*3+240","mark_scheme_working":["at x=3, y=3(3^4)-8(3^3)-6(3^2)-72(3)+240","y=-3"],"expected_output_markers":["-3"]},{"module":"algebra","input":"36*3^2-48*3-12","mark_scheme_working":["d2y/dx2=36x^2-48x-12","at x=3, d2y/dx2=168>0","stationary point is a minimum at (3,-3)"],"expected_output_markers":["168"]}],"expected_final":["(x-3) factor","f(x)=(x-3)(x^2+x+2)","single stationary point (3,-3), minimum"]}
{"id":"madas_iygb_c2_w_q6_exact_inputs","source_pdf":"MadAsMaths papers/c2_w.pdf","question":"q6","part":"all","verdict":"testable","review_basis":"manual page-image review: c2_w questions page 3, marks page 3, solutions page 4","inputs":[{"module":"algebra","input":"coeff((9/(2*x)-2*x^2/3)^13,x,11)","mark_scheme_working":["general term is C(13,r)(9/(2x))^(13-r)(-2x^2/3)^r","power of x is -(13-r)+2r=-13+3r","set -13+3r=11, giving r=8","coefficient is C(13,8)(9/2)^5(-2/3)^8=92664"],"expected_output_markers":["x^11 terms: (92664*x^11)","Coefficient = 92664"]}],"expected_final":["coefficient=92664"]}
