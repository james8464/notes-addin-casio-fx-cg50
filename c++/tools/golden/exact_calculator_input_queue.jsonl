{"id":"madas_iygb_c2_w_q10_exact_inputs","source_pdf":"MadAsMaths papers/c2_w.pdf","question":"q10","part":"a-b","verdict":"partial","review_basis":"manual page-image review: c2_w questions page 6, marks page 6, solutions page 6","inputs":[{"module":"algebra","input":"solve(0.4/2*(a/2+a/4+2*(5*a/12+5*a/14+5*a/16+5*a/18))=701.2,a)","mark_scheme_working":["five strips from x=1 to x=3 have width h=0.4","y-values are a/2, 5a/12, 5a/14, 5a/16, 5a/18, a/4","trapezium rule gives h/2[first+last+2(sum of rest)]","1753a/2520=701.2, so a=1008"],"expected_output_markers":["1753/2520*a = 3506/5","a = [1008]"]},{"module":"algebra","input":"method=numeric,701.2/2*5","mark_scheme_working":["f(x)=a/(x+1) transforms to 5a/(2x+1) using f(2x) then vertical scale 5","the interval 0.5 to 1.5 maps to x=1 to x=3 under u=2x","horizontal scale halves the area and vertical scale multiplies it by 5","approximate integral is 701.2/2*5=1753"],"expected_output_markers":["1753"]}],"expected_final":["a=1008","integral approximately 1753"],"unsupported_reason":"graph transformation explanation is manual/contextual"}
