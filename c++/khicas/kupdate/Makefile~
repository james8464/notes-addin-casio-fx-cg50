CXX	= sh3eb-elf-g++
CC	= sh3eb-elf-gcc
AR	= sh3eb-elf-gcc-ar
RANLIB	= sh3eb-elf-gcc-ranlib
OBJCOPY = sh3eb-elf-objcopy

RM	= /bin/rm

# if -DGINT_MALLOC, define GINT_MALLOC in stdlib.c (or Makefile there) and rm kgen.o main.o
FLTO = # -flto # does not work for 2 addins
# if comiling without bignum, change to tommath in config.h and link with libtommath
#if compiling with bignum, link to cutils.o and libbf.o
FULL = -DCONFIG_BIGNUM -DCONFIG_VERSION=\"2020-11-08\" -DMICROPY_LIB 
CXXFLAGS1 = -Wno-narrowing -Wno-write-strings -O3 -mb -m4a-nofpu  -mhitachi -std=c++11 -fpermissive $(FLTO) -fno-use-cxa-atexit -fno-threadsafe-statics -fno-strict-aliasing -fno-exceptions -DHAVE_CONFIG_H -DTIMEOUT -DRELEASE  -I. -I/home/parisse/casiolocal/include/ustl -DFILEICON -DKMALLOC  -DGINT_MALLOC -DTURTLETAB $(FULL)  # -fno-rtti  #  -DNO_TEMPLATE_MULTGCD -DGIAC_GENERIC_CONSTANTS -fno-zero-initialized-in-bss -ffunction-sections -fdata-sections -ffast-math

CXXFLAGS = -Wno-narrowing -Wno-write-strings -g -Os -mb -m4a-nofpu  -mhitachi -std=c++11 -fpermissive $(FLTO) -fno-use-cxa-atexit -fno-threadsafe-statics -fno-strict-aliasing -fno-exceptions -DHAVE_CONFIG_H -DTIMEOUT -DRELEASE  -I. -I/home/parisse/casiolocal/include/ustl -DFILEICON   -DTURTLETAB  -DGINT_MALLOC -DKMALLOC $(FULL) # -fno-rtti  #  -DNO_TEMPLATE_MULTGCD -DGIAC_GENERIC_CONSTANTS -fno-zero-initialized-in-bss -ffunction-sections -fdata-sections -ffast-math

CFLAGS = -Wno-narrowing -Wno-write-strings -Os -mb -m4a-nofpu  -mhitachi $(FLTO) -fno-strict-aliasing -DFXCG -DHAVE_CONFIG_H -DTIMEOUT -DRELEASE  -I. -I/home/parisse/casiolocal/include/ustl -DFILEICON  -DTURTLETAB  -DGINT_MALLOC -DKMALLOC  $(FULL)  # -DQUICKJS  -fno-rtti  #  -DNO_TEMPLATE_MULTGCD -DGIAC_GENERIC_CONSTANTS -fno-zero-initialized-in-bss -ffunction-sections -fdata-sections -ffast-math


LDFLAGS =  -g -static -nostdlib -Tprizm.ld -Wl,--gc-sections,--print-memory-usage
LDEMUFLAGS =  -g -static -nostdlib -Tprizmemu.ld -Wl,--gc-sections,--print-memory-usage

# pour voir les conflits entre fichiers objets
# nm archive.a -f posix | sed -E '/:$/ d; /[^ ]+ [a-zU]/ d; s/^([^ ]+).*$/\1/'
# sh3eb-elf-size *.o pour avoir les tailles
# zgen and zglobal were not upgraded to giac 1.7.0
CAS_OBJS = ysym2poly.o kgausspol.o kthreaded.o zcsturm.o zmaple.o zrpn.o zmoyal.o kmisc.o zpermu.o input_parser.o ksymbolic.o index.o kmodpoly.o kmodfactor.o kezgcd.o yderive.o zsolve.o yintg.o zintgab.o zlin.o zseries.o ksubst.o zvecteur.o kglobal.o zifactor.o yalg_ext.o zgauss.o zti89.o zplot.o zplot3d.o zprog.o yunary.o zusual.o yidentificateur.o kgen.o zrisch.o input_lexer.o first.o zdesolve.o ztex.o zisom.o zquater.o zadd.o overclock.o qrcodegen.o cutils.o libbf.o # memmgr.o mem.o

# old console: kmisc.cc should be compiled with -DOLD_CONSOLE
#GUI_OBJS = fileGUI.o inputGUI.o menuGUI.o textGUI.o fileProvider.o graphicsProvider.o stringsProvider.o history.o kdisplay.o dConsole.o dmain.o
# new console
GUI_OBJS = fileGUI.o menuGUI.o textGUI.o fileProvider.o graphicsProvider.o stringsProvider.o zdisplay.o console.o main.o

LIBS = -L. -L/home/parisse/casiolocal/lib -Wl,--start-group -lsupc++ -lmicropy -ltommath  -lustl -lm -lc -lgcc -Wl,--end-group
#LIBS = -L. -L/home/parisse/casiolocal/lib -Wl,--start-group  -ltommath -lustl -lm -lc -lgcc -Wl,--end-group

.PRECIOUS: libcas.a libgui.a

all: khicas90.g3a khicas90.ac2 emucas90.g3a khicas90.882 khicas50.g3a khicas50.ac2 emucas50.g3a khicas50.882 # pour la version console, supprimer le lien iostream -> iostream.new

#zdisplay.o: zdisplay.cc
#	$(CXX) $(CXXFLAGS1) -c zdisplay.cc

%.o: %.cc
	$(CXX) $(CXXFLAGS) -c $<

qrcodegen.o: qrcodegen.c
	$(CC) -std=c99 $(CFLAGS) -c $<

%.o: %.c
	$(CC) $(CFLAGS) -c $<

%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $<

libgui.a: $(GUI_OBJS)
	$(RM) -f $@
	$(AR) cru $@ $^
	$(RANLIB) $@

libcas.a: $(CAS_OBJS)
	$(RM) -f $@
	$(AR) cru $@ $^
	$(RANLIB) $@

mkhelp: mkhelp.cc
	c++ mkhelp.cc -o mkhelp

khelpfr.o: khelpfr.cc static_help.h mkhelp
	./mkhelp
	$(CXX) $(CXXFLAGS) -c khelpfr.cc -o khelpfr.o	

khelpen.o: khelpen.cc static_help.h
	./mkhelp
	$(CXX) $(CXXFLAGS) -c khelpen.cc -o khelpen.o	

khicas.elf: $(CAS_OBJS) $(GUI_OBJS) khelpfr.o catalogfr.o helpfr.o prizm.ld
	$(CXX) $(LDFLAGS) -Wl,-Map=khicas.map catalogfr.o helpfr.o $(CAS_OBJS) khelpfr.o $(GUI_OBJS) $(LIBS) -o $@
	sh3eb-elf-objdump -C -t khicas.elf | sort > dump_t

emucas.elf: $(CAS_OBJS) $(GUI_OBJS) khelpfr.o catalogfr.o helpfr.o prizmemu.ld
	$(CXX) $(LDEMUFLAGS) -Wl,-Map=emucas.map catalogfr.o helpfr.o $(CAS_OBJS) khelpfr.o $(GUI_OBJS) $(LIBS) -o $@
	sh3eb-elf-objdump -C -t emucas.elf | sort > dumpm_t

OBJFLAGS= -O binary -R .bss -R .gint_bss -R .debug_info -R .debug_abbrev -R .debug_loc -R .debug_aranges -R .debug_ranges -R .debug_line -R .debug_str -R.comment -R  debug_frame
khicas.bin: khicas.elf prizm.ld
	$(OBJCOPY) $(OBJFLAGS) -R .rominram khicas.elf khicas.bin

khicas90.ac2: khicas.elf prizm.ld
	$(OBJCOPY)  $(OBJFLAGS) -j .rominram khicas.elf khicas90.ac2
	/bin/cp  khicas90.ac2 /shared/tmp

khicas90.g3a: khicas.bin
	mkg3a -n basic:Khicas90 -n internal:KHICAS90 -V 1.8.0 -i uns:khicasio.png -i sel:khicasio1.png $^ $@
	/bin/cp khicas90.g3a /shared/tmp

emucas.bin: emucas.elf prizmemu.ld
	$(OBJCOPY) $(OBJFLAGS) -R .rominram emucas.elf emucas.bin

khicas90.882: emucas.elf prizmemu.ld
