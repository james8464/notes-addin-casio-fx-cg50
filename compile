#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if command -v docker >/dev/null 2>&1; then
  CASIO_PRIZM_MODE=khicas-source "${ROOT_DIR}/c++/tools/build_addin_prizm_docker.sh"
  exit 0
fi

echo "Docker not found."
echo "Install Docker and rerun ./compile."
exit 1
